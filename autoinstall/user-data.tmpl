#cloud-config
# Subiquity autoinstall config for Ubuntu Server 26.04 LTS.
# Docs: https://ubuntu.com/server/docs/install/autoinstall
#
# Boot the target from stock Ubuntu Server install media and point it at
# this file (second USB partition, HTTP served, or PXE — see the
# autoinstall docs for the delivery mechanism). Installer runs unattended;
# late-commands clone diskweaver-appliance into the target and hand off to
# provision/provision.sh.
#
# This file is a TEMPLATE -- it is committed with placeholders and is not
# meant to be edited in place or served as-is. Before an install, copy it
# to something gitignored (e.g. `user-data.local`) and fill in:
#   - identity.password: a real hash (mkpasswd --method=SHA-512 --rounds=4096)
#   - ssh.authorized-keys: your real public key(s)
# Serve the local copy to the installer, never the tracked template.
autoinstall:
  version: 1

  locale: en_US.UTF-8
  keyboard:
    layout: us

  # Leave the OS disk alone; DiskWeaver owns everything else. Adjust
  # `match` if the boot device isn't the smallest/first disk on your
  # hardware -- this is the one thing worth double-checking per machine.
  storage:
    layout:
      name: direct
      match:
        size: smallest

  identity:
    hostname: diskweaver-nas
    username: admin
    # Console-only fallback login (SSH below is key-only). Generate a
    # throwaway password locally, hash it, put the hash here in your
    # gitignored copy -- never the plaintext, never in git.
    #   mkpasswd --method=SHA-512 --rounds=4096
    password: "$6$REPLACE_ME_WITH_A_REAL_HASH"

  ssh:
    install-server: true
    allow-pw: false
    authorized-keys:
      - REPLACE_ME_WITH_YOUR_SSH_PUBLIC_KEY

  packages:
    - git
    - curl

  late-commands:
    - >
      curtin in-target --target=/target -- git clone --depth 1
      https://github.com/acinep/diskweaver-appliance.git
      /opt/diskweaver-appliance
    - >
      curtin in-target --target=/target -- bash
      /opt/diskweaver-appliance/provision/provision.sh

  user-data:
    disable_root: true
